    "Hide all windows" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Fenster ausblenden"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ocultar todas las ventanas"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masquer toutes les fenêtres"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ukryj wszystkie okna"
          }
