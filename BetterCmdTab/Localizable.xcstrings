    "Pass ⌘Tab through to the app instead of opening the switcher — for apps with their own window switching (virtual machines, remote desktop, some games)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘Tab an die App weiterleiten, statt den Umschalter zu öffnen — für Apps mit eigenem Fensterwechsel (virtuelle Maschinen, Remote-Desktop, manche Spiele)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transfiere ⌘Tab a la app en lugar de abrir el selector — para apps con su propio cambio de ventanas (máquinas virtuales, escritorio remoto, algunos juegos)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transmettre ⌘Tab à l’app au lieu d’ouvrir le sélecteur — pour les apps disposant de leur propre changement de fenêtre (machines virtuelles, bureau à distance, certains jeux)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przekazuj ⌘Tab do programu, zamiast otwierać przełącznik — dla programów z własnym przełączaniem okien (maszyny wirtualne, zdalny pulpit, niektóre gry)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将 ⌘Tab 传递给应用，而不是打开切换器 — 适用于拥有自身窗口切换的应用（虚拟机、远程桌面、部分游戏）。"
          }
        }
      }
    },
