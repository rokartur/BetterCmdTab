        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "向右滑动向左移动，向左滑动向右移动。"
          }
        }
      }
    },
    "Slide three fingers horizontally across the trackpad. Reads the trackpad directly, so no system setting is needed." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Streiche mit drei Fingern waagerecht über das Trackpad. Liest das Trackpad direkt aus, sodass keine Systemeinstellung erforderlich ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desliza tres dedos horizontalmente por el trackpad. Lee el trackpad directamente, por lo que no se necesita ningún ajuste del sistema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites glisser trois doigts horizontalement sur le trackpad. Lit directement le trackpad, donc aucun réglage système n’est nécessaire."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przesuń trzema palcami w poziomie po gładziku. Odczytuje gładzik bezpośrednio, więc nie jest potrzebne żadne ustawienie systemowe."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在触控板上三指水平滑动。会直接读取触控板，因此无需系统设置。"
