    "Controls whether this app shows up in the switcher.\n\n• Always — always listed.\n• With open windows — listed only while it has at least one open window.\n• Never — never listed (hidden from the switcher)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legt fest, ob diese App im Umschalter erscheint.\n\n• Immer — immer aufgeführt.\n• Mit offenen Fenstern — nur aufgeführt, solange mindestens ein Fenster geöffnet ist.\n• Nie — nie aufgeführt (im Umschalter ausgeblendet)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controla si esta app aparece en el selector.\n\n• Siempre — siempre aparece en la lista.\n• Con ventanas abiertas — aparece en la lista solo mientras tiene al menos una ventana abierta.\n• Nunca — nunca aparece en la lista (oculta del selector)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Détermine si cette app apparaît dans le sélecteur.\n\n• Toujours — toujours répertoriée.\n• Avec des fenêtres ouvertes — répertoriée uniquement lorsqu’elle possède au moins une fenêtre ouverte.\n• Jamais — jamais répertoriée (masquée du sélecteur)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Określa, czy ten program pojawia się w przełączniku.\n\n• Zawsze — zawsze na liście.\n• Z otwartymi oknami — na liście tylko wtedy, gdy ma co najmniej jedno otwarte okno.\n• Nigdy — nigdy na liście (ukryty w przełączniku)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "控制此应用是否显示在切换器中。\n\n• 始终 — 始终列出。\n• 有打开窗口时 — 仅在至少有一个打开窗口时列出。\n• 从不 — 从不列出（在切换器中隐藏）。"
          }
        }
      }
    },
    "Corner radius" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eckenradius"
