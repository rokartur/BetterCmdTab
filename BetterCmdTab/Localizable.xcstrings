    "BetterCmdTab needs Accessibility permission to handle ⌘Tab. Re-enable it in System Settings and the switcher reactivates automatically." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterCmdTab benötigt die Bedienungshilfen-Berechtigung für ⌘Tab. Aktiviere sie in den Systemeinstellungen erneut, dann reaktiviert sich der Umschalter automatisch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterCmdTab necesita el permiso de Accesibilidad para gestionar ⌘Tab. Vuelve a activarlo en Ajustes del Sistema y el conmutador se reactivará automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterCmdTab a besoin de l'autorisation d'Accessibilité pour gérer ⌘Tab. Réactive-la dans Réglages Système et le sélecteur se réactive automatiquement."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterCmdTab potrzebuje uprawnienia Dostępności, aby obsługiwać ⌘Tab. Włącz je ponownie w Ustawieniach systemowych, a przełącznik uaktywni się automatycznie."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterCmdTab 需要辅助功能权限才能处理 ⌘Tab。请在“系统设置”中重新启用，切换器会自动恢复。"
          }
        }
      }
    },
    "Bring every hidden app back." : {
      "localizations" : {
