    "Press / in the switcher to filter by app or window name." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drücke / im Umschalter, um nach App- oder Fensternamen zu filtern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulsa / en el selector para filtrar por nombre de app o de ventana."
          }
        },
