    "Give a shortcut to one app — it focuses that app, opening it first if needed." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weise einer App einen Kurzbefehl zu — er aktiviert diese App und öffnet sie zunächst, falls nötig."
